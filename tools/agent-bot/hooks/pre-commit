#!/bin/sh
# pre-commit guard (ENG-0045, decision 6): agents may only commit inside bot
# territory. Installed machine-wide via core.hooksPath, it blocks a commit
# when ALL three hold:
#   - the process carries agent-only environment markers (CLAUDECODE,
#     AI_AGENT, CODEX_*) — never editor markers, so a human in an editor
#     terminal is never evaluated at all;
#   - the commit would be attributed to the human (identity did not resolve
#     to a *[bot]* — i.e. no bot worktree config applies here);
#   - any remote points at GitHub (a remoteless scratch repo cannot
#     impersonate anyone, and agents legitimately use those for tests).
# Bot-attributed commits pass untouched. Fails open on its own errors —
# a broken guard must never brick commits machine-wide.

AGENT=""
[ "$CLAUDECODE" = "1" ] && AGENT=1
[ -n "$AI_AGENT" ] && AGENT=1
if [ -z "$AGENT" ]; then env | grep -q '^CODEX_' && AGENT=1; fi

if [ -n "$AGENT" ]; then
  NAME=$(git config user.name 2>/dev/null || true)
  case "$NAME" in
    *"[bot]"*) : ;; # resolves to a bot — legitimate agent commit
    *)
      REMOTES=$(git remote -v 2>/dev/null || true)
      case "$REMOTES" in
        *github.com*)
          echo "agent-bot guard (ENG-0045): agents may only commit changes within ~/.<tool>/worktrees/<repo>." >&2
          echo "This commit would be attributed to the human ('${NAME:-unset}'). Create or use your tool's worktree." >&2
          exit 1
          ;;
      esac
      ;;
  esac
fi

# Chain to a repo-local pre-commit so the global hooksPath never disables one.
LOCAL="$(git rev-parse --git-common-dir 2>/dev/null)/hooks/pre-commit"
HOOK_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
if [ -x "$LOCAL" ] && [ "$LOCAL" != "$HOOK_DIR/pre-commit" ]; then
  exec "$LOCAL" "$@"
fi
exit 0
