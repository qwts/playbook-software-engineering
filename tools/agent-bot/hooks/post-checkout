#!/bin/sh
# post-checkout hook — configure the agent-bot identity on a new worktree
# (ENG-0016). Git runs this on `git worktree add` regardless of which tool
# created the worktree (Codex, Cursor, VS Code, a plain terminal, anything),
# so it is the tool-agnostic trigger. The bot identity is auto-detected from
# the creating tool's own environment (see detect-harness.mjs), so no per-tool
# or per-repo configuration is required.
#
# The setup script is resolved relative to THIS hook's own location, so the
# hook works no matter where the checkout lives or what $HOME is. When this
# repo's hooks are shared to other repos via `core.hooksPath`, that path still
# points back here, so the resolution holds.
#
# It never blocks a checkout: any failure is swallowed. setup-worktree.mjs
# self-guards (only linked worktrees, only when an identity resolves), so
# running it on every checkout is safe.

HOOK_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
SETUP="$HOOK_DIR/../setup-worktree.mjs"
if [ -f "$SETUP" ] && command -v node >/dev/null 2>&1; then
  node "$SETUP" || true
fi

# Because this hook is installed via a global core.hooksPath, it shadows each
# repo's own hooks/post-checkout. Chain through to a repo-local one if present
# (and not this same file), so setting the global path never silently disables
# another repo's hook.
# --git-common-dir, not --git-path hooks: the latter honors core.hooksPath
# and would resolve back to this global directory instead of the repo's own.
LOCAL="$(git rev-parse --git-common-dir 2>/dev/null)/hooks/post-checkout"
if [ -x "$LOCAL" ] && [ "$LOCAL" != "$HOOK_DIR/post-checkout" ]; then
  "$LOCAL" "$@"
fi
