{
  "include": ["docs/**/*.md", "README.md", "CONTRIBUTING.md", "usage.md", "AGENTS.md"],
  "indexes": ["README.md"],
  "tokenBudgets": {
    "perDoc": 2600,
    "bankSlack": 0.25,
    "overrides": [
      {
        "path": "usage.md",
        "budget": 4000,
        "reason": "walkthrough of the full playbook flow; splitting it would break the single narrative it exists to provide"
      },
      {
        "path": "docs/reference/agent-bot-identity.md",
        "budget": 3000,
        "reason": "the identity runbook covers one system whose lanes (setup, worktrees, gh shim, whoami, verification, failure modes) are only safe read together; it has been prose-tightened to the bone and splitting it would separate the impersonation hazards from their remedies"
      }
    ],
    "contextSets": []
  },
  "structure": {
    "maxHeadingDepth": 4,
    "summaryWithinTokens": 250,
    "requiredFields": [
      {
        "glob": "docs/decisions/ENG-*.md",
        "fields": [
          { "name": "Status", "pattern": "^(Proposed|Accepted|Superseded by ENG-\\d{4})$" },
          { "name": "Date", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        ]
      },
      {
        "glob": "docs/decisions/ENG-*.md",
        "exclude": ["docs/decisions/ENG-000?-*.md", "docs/decisions/ENG-0010-*.md"],
        "fields": [
          { "name": "Issue", "pattern": "^qwts/[\\w.-]+#\\d+$" }
        ]
      },
      {
        "glob": "docs/decisions/ENG-000?-*.md",
        "fields": [
          { "name": "Issue", "pattern": "^(qwts/[\\w.-]+#\\d+|predates issue-first \\(ENG-0013\\))$" }
        ]
      },
      {
        "glob": "docs/decisions/ENG-0010-*.md",
        "fields": [
          { "name": "Issue", "pattern": "^(qwts/[\\w.-]+#\\d+|predates issue-first \\(ENG-0013\\))$" }
        ]
      }
    ]
  },
  "antiPatterns": {
    "positionalReferences": true,
    "unresolvedPlaceholders": true,
    "duplicateParagraphs": { "minLength": 160, "allow": [] },
    "terminology": []
  },
  "integrity": {
    "links": true,
    "orphans": true,
    "stalePaths": { "roots": ["docs", "tools"] }
  },
  "decisionSeries": {
    "glob": "docs/decisions/ENG-*.md",
    "issueField": "Issue",
    "homeRepo": "qwts/playbook-engineering",
    "grandfathered": ["docs/decisions/ENG-000?-*.md", "docs/decisions/ENG-001?-*.md"]
  }
}
